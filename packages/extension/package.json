{
  "name": "file-nesting-explorer",
  "publisher": "GroverLee",
  "displayName": "React File Nesting Explorer: Make React Projects simple",
  "description": "Create and manage React components with ease. File Nesting Explorer lets your project structure finally reflect how you already visualize your UI.",
  "icon": "logo.png",
  "author": "Grover Lee",
  "version": "0.6.0",
  "license": "MIT",
  "galleryBanner": {
    "color": "#100f11",
    "theme": "dark"
  },
  "badges": [
    {
      "url": "https://img.shields.io/github/stars/brucegroverlee/file-nesting-explorer",
      "description": "File Nesting Explorer on Github",
      "href": "https://github.com/brucegroverlee/file-nesting-explorer"
    }
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/brucegroverlee/file-nesting-explorer"
  },
  "bugs": {
    "url": "https://github.com/brucegroverlee/file-nesting-explorer/issues"
  },
  "scripts": {
    "vscode:prepublish": "npm run bundle -- --minify",
    "compile": "tsc -b",
    "bundle": "npm run compile && node ./esbuild.config.js",
    "watch": "tsc -b --watch",
    "watch:bundle": "node ./esbuild.config.js --watch",
    "lint": "eslint src",
    "pretest": "npm run compile && npm run lint",
    "test": "vscode-test",
    "preui:test": "npm run compile",
    "ui:test": "env -u ELECTRON_RUN_AS_NODE extest setup-and-run --code_version max out/ui-test/**/*.test.js",
    "package": "vsce package --no-dependencies",
    "publish": "vsce publish --no-dependencies"
  },
  "dependencies": {
    "@file-nesting/shared": "*",
    "mixpanel": "^0.19.1"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.6",
    "@types/node": "20.x",
    "@types/sinon": "^17.0.3",
    "@types/vscode": "^1.105.0",
    "@typescript-eslint/eslint-plugin": "^8.7.0",
    "@typescript-eslint/parser": "^8.7.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.27.7",
    "eslint": "^9.11.1",
    "sinon": "^19.0.2",
    "typescript": "^5.6.2",
    "vscode-extension-tester": "^8.23.0"
  },
  "engines": {
    "vscode": "^1.105.0"
  },
  "categories": [
    "Visualization",
    "Programming Languages",
    "Other"
  ],
  "keywords": [
    "react",
    "nextjs",
    "refactor",
    "components",
    "javascript",
    "typescript",
    "ui components",
    "frontend tools",
    "file",
    "nesting",
    "explorer",
    "file nesting",
    "file nesting explorer",
    "react file nesting",
    "clean code"
  ],
  "activationEvents": [
    "onView:fileNestingExplorer",
    "onView:reactExplorer",
    "onLanguage:javascriptreact",
    "onLanguage:typescriptreact"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "File Nesting Explorer",
      "properties": {
        "fileNestingExplorer.fileNestingExtensions": {
          "type": "array",
          "default": [
            "tsx",
            "jsx",
            "ts",
            "js"
          ],
          "description": "File extensions that are allowed to be nested."
        },
        "fileNestingExplorer.fileNestingPrefix": {
          "type": "string",
          "default": "@",
          "description": "Prefix for the nesting folder container."
        }
      }
    },
    "commands": [
      {
        "command": "fileNestingExplorer.newFile",
        "title": "New File...",
        "icon": "$(new-file)"
      },
      {
        "command": "fileNestingExplorer.newFolder",
        "title": "New Folder...",
        "icon": "$(new-folder)"
      },
      {
        "command": "fileNestingExplorer.refresh",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "fileNestingExplorer.newNestedFile",
        "title": "New Nested File...",
        "icon": "$(new-file)"
      },
      {
        "command": "fileNestingExplorer.newNestedFileFromSelection",
        "title": "Create Nested File From Selection"
      },
      {
        "command": "fileNestingExplorer.newNestedFolder",
        "title": "New Nested Folder...",
        "icon": "$(new-folder)"
      },
      {
        "command": "fileNestingExplorer.createFileNestingContainer",
        "title": "Enable Nested Files"
      },
      {
        "command": "fileNestingExplorer.deleteFileNestingContainer",
        "title": "Delete Nested Files / Remove Expand Icon",
        "icon": "$(trash)"
      },
      {
        "command": "fileNestingExplorer.cut",
        "title": "Cut"
      },
      {
        "command": "fileNestingExplorer.copy",
        "title": "Copy"
      },
      {
        "command": "fileNestingExplorer.paste",
        "title": "Paste"
      },
      {
        "command": "fileNestingExplorer.copyPath",
        "title": "Copy Path"
      },
      {
        "command": "fileNestingExplorer.copyRelativePath",
        "title": "Copy Relative Path"
      },
      {
        "command": "fileNestingExplorer.rename",
        "title": "Rename"
      },
      {
        "command": "fileNestingExplorer.delete",
        "title": "Delete"
      },
      {
        "command": "fileNestingExplorer.openEditor",
        "title": "Open Editor"
      },
      {
        "command": "fileNestingExplorer.moveUp",
        "title": "Move Up"
      },
      {
        "command": "fileNestingExplorer.moveDown",
        "title": "Move Down"
      },
      {
        "command": "fileNestingExplorer.restoreSortingAlphabetically",
        "title": "Restore Sorting Alphabetically"
      },
      {
        "command": "fileNestingExplorer.editSortingFile",
        "title": "Edit Sorting File"
      },
      {
        "command": "fileNestingExplorer.newNestedFileHint",
        "title": "New Nested File..."
      },
      {
        "command": "fileNestingExplorer.newNestedFolderHint",
        "title": "New Nested Folder..."
      },
      {
        "command": "fileNestingExplorer.openDocumentation",
        "title": "See React File Nesting Documentation"
      },
      {
        "command": "fileNestingExplorer.findInFolder",
        "title": "Find in Folder..."
      }
    ],
    "views": {
      "explorer": [
        {
          "id": "fileNestingExplorer",
          "name": "File Nesting Explorer"
        },
        {
          "id": "reactExplorer",
          "name": "React Explorer",
          "type": "webview"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "fileNestingExplorer.newFile",
          "when": "view == fileNestingExplorer || view == reactExplorer",
          "group": "navigation@1"
        },
        {
          "command": "fileNestingExplorer.newFolder",
          "when": "view == fileNestingExplorer || view == reactExplorer",
          "group": "navigation@1"
        },
        {
          "command": "fileNestingExplorer.refresh",
          "when": "view == fileNestingExplorer || view == reactExplorer",
          "group": "navigation@1"
        }
      ],
      "view/item/context": [
        {
          "command": "fileNestingExplorer.newFile",
          "when": "view == fileNestingExplorer && viewItem == folder",
          "group": "group1"
        },
        {
          "command": "fileNestingExplorer.newFolder",
          "when": "view == fileNestingExplorer && viewItem == folder",
          "group": "group1"
        },
        {
          "command": "fileNestingExplorer.newNestedFile",
          "when": "view == fileNestingExplorer && (viewItem == file_with_nesting_extension || viewItem == nesting_file)",
          "group": "group1"
        },
        {
          "command": "fileNestingExplorer.newNestedFolder",
          "when": "view == fileNestingExplorer && (viewItem == file_with_nesting_extension || viewItem == nesting_file)",
          "group": "group1"
        },
        {
          "command": "fileNestingExplorer.createFileNestingContainer",
          "when": "view == fileNestingExplorer && viewItem == file_with_nesting_extension",
          "group": "group2"
        },
        {
          "command": "fileNestingExplorer.openDocumentation",
          "when": "view == fileNestingExplorer",
          "group": "group3"
        },
        {
          "command": "fileNestingExplorer.findInFolder",
          "when": "view == fileNestingExplorer && viewItem == folder",
          "group": "group4"
        },
        {
          "command": "fileNestingExplorer.cut",
          "when": "view == fileNestingExplorer",
          "group": "group5"
        },
        {
          "command": "fileNestingExplorer.copy",
          "when": "view == fileNestingExplorer",
          "group": "group5"
        },
        {
          "command": "fileNestingExplorer.paste",
          "when": "view == fileNestingExplorer",
          "group": "group5"
        },
        {
          "command": "fileNestingExplorer.copyPath",
          "when": "view == fileNestingExplorer",
          "group": "group6"
        },
        {
          "command": "fileNestingExplorer.copyRelativePath",
          "when": "view == fileNestingExplorer",
          "group": "group6"
        },
        {
          "command": "fileNestingExplorer.moveUp",
          "when": "view == fileNestingExplorer",
          "group": "group7@1"
        },
        {
          "command": "fileNestingExplorer.moveDown",
          "when": "view == fileNestingExplorer",
          "group": "group7@2"
        },
        {
          "command": "fileNestingExplorer.restoreSortingAlphabetically",
          "when": "view == fileNestingExplorer && (viewItem == folder || viewItem == nesting_file)",
          "group": "group7@3"
        },
        {
          "command": "fileNestingExplorer.editSortingFile",
          "when": "view == fileNestingExplorer && (viewItem == folder || viewItem == nesting_file)",
          "group": "group7@4"
        },
        {
          "command": "fileNestingExplorer.delete",
          "when": "view == fileNestingExplorer",
          "group": "group8@1"
        },
        {
          "command": "fileNestingExplorer.deleteFileNestingContainer",
          "when": "view == fileNestingExplorer && viewItem == nesting_file",
          "group": "group8@2"
        },
        {
          "command": "fileNestingExplorer.rename",
          "when": "view == fileNestingExplorer",
          "group": "group8@3"
        }
      ],
      "explorer/context": [
        {
          "command": "fileNestingExplorer.newNestedFileHint",
          "when": "!explorerResourceIsFolder && resourceExtname =~ /\\.(tsx|jsx|ts|js)$/",
          "group": "navigation@0"
        },
        {
          "command": "fileNestingExplorer.newNestedFolderHint",
          "when": "!explorerResourceIsFolder && resourceExtname =~ /\\.(tsx|jsx|ts|js)$/",
          "group": "navigation@1"
        }
      ],
      "editor/context": [
        {
          "command": "fileNestingExplorer.newNestedFileFromSelection",
          "when": "editorHasSelection",
          "group": "fileNestingExplorer@9"
        }
      ]
    },
    "keybindings": [
      {
        "command": "fileNestingExplorer.cut",
        "key": "ctrl+x",
        "mac": "cmd+x",
        "when": "fileNestingExplorer"
      },
      {
        "command": "fileNestingExplorer.copy",
        "key": "ctrl+c",
        "mac": "cmd+c",
        "when": "fileNestingExplorer"
      },
      {
        "command": "fileNestingExplorer.paste",
        "key": "ctrl+v",
        "mac": "cmd+v",
        "when": "fileNestingExplorer"
      },
      {
        "command": "fileNestingExplorer.copyPath",
        "key": "ctrl+shift+c",
        "mac": "alt+cmd+c",
        "when": "fileNestingExplorer"
      },
      {
        "command": "fileNestingExplorer.copyRelativePath",
        "key": "ctrl+alt+c",
        "mac": "alt+shift+cmd+c",
        "when": "fileNestingExplorer"
      },
      {
        "command": "fileNestingExplorer.delete",
        "key": "delete",
        "mac": "cmd+backspace",
        "when": "fileNestingExplorer"
      }
    ]
  }
}
